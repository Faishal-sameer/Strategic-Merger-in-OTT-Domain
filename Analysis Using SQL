--8.  Upgrade Patterns 
-- What are the most common upgrade transitions (e.g., Free to Basic, Free to VIP, 
-- Free to Premium) for LioCinema and Jotstar? How do these differ across platforms?

-- Hotstar Upgrade
select
	*,
	round(cast(100.0*total_upgrade/Total_User as float),2) as [Growth %]
from(
SELECT
	COUNT(*) AS Total_User,
	sum(case
			when subscription_plan='Free' and new_subscription_plan in ('VIP', 'Premium')  THEN 1
			when subscription_plan='Premium' and new_subscription_plan='VIP' then 1 
		else 0 end
					) as total_upgrade
FROM
	DBO.Hotstar_subscribers
)sub

-- JIO-Cinema
select
	*,
	round(cast(100.0*Total_Upgrade/Total_User as float),2) as [Growth (%)]
from(
select
	count(distinct user_id) as Total_User,
	Sum(Case 
			when subscription_plan='Free' and new_subscription_plan in ('Basic', 'Premium') then 1
			when subscription_plan='Basic' and new_subscription_plan ='Premium' then 1 
			else 0 end	) as Total_Upgrade
from
	dbo.Jio_subscribers
)Sub


