--6. Inactivity Correlation 
-- How do inactivity patterns correlate with total watch time or average watch time? Are 
--less engaged users more likely to become inactive? 

-- HOTSTAR USER 
SELECT
	*,
	TOTAL_WATCH_HOUR/TOTAL_USER AS AVERANGE_WATCH_HOUR,
	TOTAL_ACTIVE_HOUR/ACTIVE_USER AS AVERAGE_ACTIVE_WATCH_HOUR,
	TOTAL_UNACTIVE_HOUR/UNACTIVE_USER AS AVERAGE_UNACTIVE_WATCH_HOUR
FROM(
SELECT
	B.city_tier,
	COUNT(DISTINCT A.user_id) AS TOTAL_USER,
	SUM(A.total_watch_time_mins)/60 AS TOTAL_WATCH_HOUR,
	SUM(CASE WHEN B.last_active_date='NULL' THEN A.total_watch_time_mins END)/60 AS TOTAL_ACTIVE_HOUR,
	SUM(CASE WHEN B.last_active_date<>'NULL' THEN A.total_watch_time_mins END)/60 AS TOTAL_UNACTIVE_HOUR,
	COUNT(DISTINCT(CASE WHEN B.last_active_date ='NULL' THEN A.user_id END )) AS ACTIVE_USER,
	COUNT(DISTINCT(CASE WHEN B.last_active_date <>'NULL' THEN A.user_id END )) AS UNACTIVE_USER
FROM
	DBO.Hotstar_content_consumption a
join
	DBO.Hotstar_subscribers B
ON
	A.user_id=B.user_id
GROUP BY
	B.city_tier
)SUB

-- Jio

SELECT
	*,
	TOTAL_WATCH_HOUR/TOTAL_USER AS AVERANGE_WATCH_HOUR,
	TOTAL_ACTIVE_HOUR/ACTIVE_USER AS AVERAGE_ACTIVE_WATCH_HOUR,
	TOTAL_UNACTIVE_HOUR/UNACTIVE_USER AS AVERAGE_UNACTIVE_WATCH_HOUR
FROM(
SELECT
	B.city_tier,
	COUNT(DISTINCT A.user_id) AS TOTAL_USER,
	SUM(A.total_watch_time_mins)/60 AS TOTAL_WATCH_HOUR,
	SUM(CASE WHEN B.last_active_date='NULL' THEN A.total_watch_time_mins END)/60 AS TOTAL_ACTIVE_HOUR,
