-- 1. Total Users & Growth Trends 
--  What is the total number of users for LioCinema and Jotstar, and how do they 
-- compare in terms of growth trends (January–November 2024)?

-- Hotstar

WITH CTE AS(
SELECT
	*,
	lag(CM_USER,1,0)OVER(ORDER BY MONTHS ASC) AS PREVIOUSMONTH_USER
FROM(
select 
	MONTH(A.SUBSCRIPTION_DATE) AS MONTHS,
	COUNT(DISTINCT A.USER_ID) AS CM_USER
from dbo.Hotstar_subscribers A
JOIN
	DBO.Hotstar_content_consumption B
ON
	A.user_id=B.user_id
WHERE
	YEAR(A.SUBSCRIPTION_DATE)=2024
GROUP BY
	MONTH(A.SUBSCRIPTION_DATE)
)SUB
)
SELECT
	*,
	ROUND(CAST(CASE WHEN PREVIOUSMONTH_USER=0 THEN 0 ELSE (100.0 * (cm_user*1.0/PREVIOUSMONTH_USER-1)) END  AS FLOAT),2)AS PERCENTA_GROWTH
FROM
	CTE
WHERE
	PREVIOUSMONTH_USER>0

-- JIO 

WITH CTE AS(
SELECT
	*,
	LAG(TOTAL_USER,1,0)OVER(ORDER BY MONTHS ASC) AS PREVIOUSMONTH_USER
FROM(
select 
	MONTH(A.SUBSCRIPTION_DATE) AS MONTHS,
	COUNT(DISTINCT A.USER_ID) AS TOTAL_USER
from dbo.JIO_subscribers A
JOIN
	DBO.JIO_content_consumption B
ON
	A.user_id=B.user_id
WHERE
	YEAR(A.SUBSCRIPTION_DATE)=2024
GROUP BY
	MONTH(A.SUBSCRIPTION_DATE)
)SUB
)
SELECT
	*,
	ROUND(CAST(CASE WHEN PREVIOUSMONTH_USER=0 THEN 0 ELSE 100*((1.0*TOTAL_USER/PREVIOUSMONTH_USER*1.0)-1) END  AS FLOAT),2)AS PERCENTA_GROWTH
FROM
	CTE
WHERE
	PREVIOUSMONTH_USER>0


