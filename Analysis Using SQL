--5. Watch Time Analysis 
-- What is the average watch time for LioCinema vs. Jotstar during the analysis period? 
--How do these compare by city tier and device type?

-- HOTSTAR
-- AVERAGE WATCH TIME IN CITY TIER
select
	age_group,
	sum(case when city_tier= 'Tier 1' then total_user end) as tier_1_user,
	sum(case when city_tier= 'Tier 2' then total_user end) as tier_2_user,
	sum(case when city_tier= 'Tier 3' then total_user end) as tier_3_user,
	sum(case when city_tier= 'Tier 1' then total_hour end) as [tier_1_Watch(hr)],
	sum(case when city_tier= 'Tier 2' then total_hour end) as [tier_2_watch(hr)],
	sum(case when city_tier= 'Tier 3' then total_hour end) as [tier_3_watch(hr)]
from(
select
	age_group,
	b.city_tier,
	COUNT(distinct a.user_id) as total_user,
	sum(a.total_watch_time_mins)/60 as total_hour
from
	dbo.Hotstar_content_consumption a
join
	dbo.Hotstar_subscribers b
on
	a.user_id=b.user_id
group by
	b.city_tier, age_group
)sub
group by age_group

